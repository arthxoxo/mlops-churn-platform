# ── AWS Configuration ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_ACCOUNT_ID=123456789012

# ── S3 (free tier: 5GB storage) ─────────────────────────────────────────────
S3_BUCKET=your-mlops-bucket

# ── SNS (free tier: 1M publishes/month) ─────────────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:mlops-alerts

# ── Lambda (free tier: 1M requests/month) ────────────────────────────────────
LAMBDA_FUNCTION_NAME=mlops-drift-monitor
LAMBDA_ROLE_ARN=arn:aws:iam::123456789012:role/LambdaRole
DRIFT_THRESHOLD=0.20

# ── CI/CD Automation Flags (optional) ──────────────────────────────────────
LAMBDA_DEPLOY_ENABLED=true
SERVING_FUNCTION_NAME=mlops-churn-fastapi
DRIFT_FUNCTION_NAME=mlops-drift-monitor
MONITORING_SETUP_ENABLED=false
SNS_TOPIC_NAME=mlops-alerts

# ── Pipeline ─────────────────────────────────────────────────────────────────
ACCURACY_THRESHOLD=0.80

# ── Data & Model Paths (optional — defaults to workspace-relative) ──────────
# These are handled by src/config.PathConfig and default to repo-relative paths.
# Only set these if you want to override the default locations.
# DATA_RAW_DIR=/path/to/raw/data
# DATA_PROCESSED_DIR=/path/to/processed/data
# MODEL_DIR=models
# ARTIFACTS_DIR=artifacts
# EVALUATION_OUTPUT_DIR=evaluation_output

# ── MLflow (local, free) ─────────────────────────────────────────────────────
# Defaults to ./mlruns (workspace-relative). Only override if needed.
# MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=churn-prediction

# ── Model Serving ────────────────────────────────────────────────────────────
PORT=8080
