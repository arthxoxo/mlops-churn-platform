# ── AWS Configuration ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_ACCOUNT_ID=123456789012

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET=your-mlops-bucket

# ── SageMaker ────────────────────────────────────────────────────────────────
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/SageMakerRole

# ── SNS (Alerting) ──────────────────────────────────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:mlops-alerts

# ── Lambda ───────────────────────────────────────────────────────────────────
LAMBDA_FUNCTION_NAME=mlops-drift-monitor
DRIFT_THRESHOLD=0.20

# ── Model Serving ────────────────────────────────────────────────────────────
MODEL_DIR=models
PORT=8080

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=churn-prediction
